# Database (porta 5433 para não conflitar com outras instâncias locais)
DATABASE_URL="postgresql://cafe:cafe@localhost:5433/cafe?schema=public"

# Redis (porta 6380 para não conflitar com outras instâncias locais)
REDIS_URL="redis://localhost:6380"

# API
API_PORT=3333
API_HOST=0.0.0.0
API_URL=http://localhost:3333

# Web
WEB_PORT=3000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333

# Better Auth
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
BETTER_AUTH_URL=http://localhost:3333

# Cloudinary (Passo 2.2)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed de produção/local
# O seed apaga os dados existentes antes de recriar a base inicial.
SEED_CONFIRM_RESET=false
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_NAME=
SEED_ORG_NAME="Café Beniel"
SEED_ORG_SLUG="cafe-beniel"
SEED_ORG_PHONE=
# Formato padrão: "Rua, número - Bairro - CEP"
SEED_ORG_ADDRESS=
SEED_TABLE_COUNT=10
SEED_DELIVERY_ENABLED=true
SEED_DEFAULT_DELIVERY_FEE=0.00
# true carrega o cardapio inicial do primeiro tenant; clientes futuros cadastram pela UI.
SEED_LOAD_INITIAL_CATALOG=true
# Formato: "Bairro:5.00;Outro bairro:7.00"
SEED_DELIVERY_FEES=
SEED_PRINTER_NAME="Impressora principal"
# Opcional. Se vazio, o seed gera um token novo e exibe no terminal.
SEED_PRINTER_TOKEN=

# Super admin do SaaS — emails separados por vírgula. Sincronizado no boot da API.
SUPER_ADMIN_EMAILS=
# Valor mensal do plano Pro usado em métricas de MRR no painel admin
PRO_PLAN_PRICE=99
