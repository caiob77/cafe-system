# Variáveis usadas pela stack docker-compose.prod.yml.
# Copiar para .env.production e preencher com valores reais.

# --- Domínio público ---------------------------------------------------------
DOMAIN=cafe.exemplo.com
LETSENCRYPT_EMAIL=voce@exemplo.com

# --- Postgres (host interno do compose: "postgres:5432") ---------------------
POSTGRES_USER=cafe
POSTGRES_PASSWORD=trocar-por-senha-forte
POSTGRES_DB=cafe

# --- API ---------------------------------------------------------------------
# Better Auth — gerar com: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://cafe.exemplo.com
WEB_URL=https://cafe.exemplo.com

# Super admin do SaaS (emails separados por vírgula)
SUPER_ADMIN_EMAILS=
PRO_PLAN_PRICE=99

# Cloudinary (opcional, p/ uploads de imagem)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Web ---------------------------------------------------------------------
# Em produção o front fala com a mesma origem (nginx faz proxy de /api/).
NEXT_PUBLIC_API_URL=https://cafe.exemplo.com
