{
  "name": "@cafe/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env ./src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env ./dist/server.js",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cafe/db": "workspace:*",
    "@cafe/shared": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "better-auth": "^1.6.11",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3"
  }
