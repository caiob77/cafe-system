# Print-agent placeholder (sem impressora física ainda).
# Para usar: faça login no web app, copie o cookie 'better-auth.session_token'
# e cole abaixo. O agent conecta no WS da API e simula impressão no console.

API_BASE_URL=http://localhost:3333
API_WS_URL=ws://localhost:3333/api/v1/realtime

# Cookie completo da sessão (formato: better-auth.session_token=VALUE)
SESSION_COOKIE=
